        "name": "unpack",
        "script": "const records = bh.local.response?.payload?.records || [];\nconst vehicle = records[0] || null;\n\nif (vehicle) {\n  bh.local.output = {\n    success: true,\n    vehicle: {\n      vehicle_type: vehicle.vehicle_type,\n      model: vehicle.model,\n      is_high_end: vehicle.is_high_end\n    }\n  };\n} else {\n  bh.local.output = {\n    success: false,\n    error: \"Vehicle not found\"\n  };\n}",
